#!/usr/bin/env bash
#
# ai-stack-smoke-test - Verify AI Stack services are running
#
# Usage: ai-stack-smoke-test
#

set -euo pipefail

# Source common.sh if available
COMMON_SH="${XDG_CONFIG_HOME:-$HOME/.config}/ai-stack/lib/common.sh"
if [ -f "$COMMON_SH" ]; then
    source "$COMMON_SH"
fi

# Colors (fallback if common.sh not available)
: "${RED:='\033[0;31m'}"
: "${GREEN:='\033[0;32m'}"
: "${YELLOW:='\033[1;33m'}"
: "${BLUE:='\033[0;34m'}"
: "${NC:='\033[0m'}"

passed=0
failed=0

check() {
    local name="$1"
    local url="$2"
    local method="${3:-GET}"
    local data="${4:-}"

    if [ "$method" = "POST" ] && [ -n "$data" ]; then
        if curl -sf --max-time 5 -X POST "$url" -d "$data" > /dev/null 2>&1; then
            echo -e "  ${GREEN}✓${NC} $name"
            ((passed++))
        else
            echo -e "  ${RED}✗${NC} $name"
            ((failed++))
        fi
    else
        if curl -sf --max-time 5 "$url" > /dev/null 2>&1; then
            echo -e "  ${GREEN}✓${NC} $name"
            ((passed++))
        else
            echo -e "  ${RED}✗${NC} $name"
            ((failed++))
        fi
    fi
}

echo -e "${BLUE}AI Stack Smoke Test${NC}"
echo ""

# Containers
echo -e "${BLUE}Containers:${NC}"
check "Open WebUI" "http://localhost:7860/health"

# GPU Services
echo ""
echo -e "${BLUE}GPU Services:${NC}"
check "Whisper STT" "http://localhost:7861/health"
check "Whisper Ready" "http://localhost:7861/ready"
check "llama.cpp" "http://localhost:8080/health"
check "STT Proxy" "http://localhost:7866/health"

# Summary
echo ""
echo -e "${BLUE}Results:${NC} ${GREEN}$passed passed${NC}, ${RED}$failed failed${NC}"

if [ "$failed" -gt 0 ]; then
    exit 1
fi
