#!/usr/bin/env bash
#
# bin/ai-stack — AI Stack Management CLI
#
# Installed to: ~/.local/bin/ai-stack
# Source of truth: ~/.config/ai-stack/lib/common.sh
#
set -e

# Load shared constants and helpers
_COMMON="${XDG_CONFIG_HOME:-$HOME/.config}/ai-stack/lib/common.sh"
if [ ! -f "$_COMMON" ]; then
    echo "ERROR: common.sh not found at $_COMMON"
    echo "Run: ai-stack install base"
    exit 1
fi
# shellcheck source=/dev/null
source "$_COMMON"

# Compose file lives in XDG config (installed by install base)
COMPOSE_FILE="$AI_STACK_CONFIG_DIR/compose.yaml"

COMMAND=$1
shift || true

case "$COMMAND" in
    up)
        load_env
        podman compose -f "$COMPOSE_FILE" up -d
        ;;
    down)
        podman compose -f "$COMPOSE_FILE" down
        ;;
    restart)
        load_env
        podman compose -f "$COMPOSE_FILE" restart "$@"
        ;;
    status)
        podman compose -f "$COMPOSE_FILE" ps
        ;;
    logs)
        SERVICE="${1:-all}"
        shift 2>/dev/null || true

        case "$SERVICE" in
            all)
                echo -e "\033[0;34m=== AI Stack Logs ===\033[0m"
                echo ""
                # Bare-metal services
                for svc in whisper-server llama-cpp stt-proxy; do
                    if systemctl --user is-active "$svc" &>/dev/null; then
                        echo -e "\033[1;33m[$svc]\033[0m"
                        journalctl --user -u "$svc" -o short --no-pager -n 10 2>/dev/null || echo "  (no logs)"
                        echo ""
                    fi
                done
                # Container services
                if [ -f "$COMPOSE_FILE" ]; then
                    for ctr in $(podman compose -f "$COMPOSE_FILE" ps --services 2>/dev/null); do
                        echo -e "\033[1;33m[$ctr]\033[0m"
                        podman logs "$ctr" --tail=10 --no-log-group 2>/dev/null | head -10 || echo "  (no logs)"
                        echo ""
                    done
                fi
                ;;
            errors)
                echo -e "\033[0;31m=== Errors from all services ===\033[0m"
                echo ""
                for svc in whisper-server llama-cpp stt-proxy; do
                    journalctl --user -u "$svc" -o short --no-pager -n 100 2>/dev/null | grep -iE "error|warn|fail|crit" && echo "" || true
                done
                if [ -f "$COMPOSE_FILE" ]; then
                    for ctr in $(podman compose -f "$COMPOSE_FILE" ps --services 2>/dev/null); do
                        podman logs "$ctr" --tail=100 2>/dev/null | grep -iE "error|warn|fail|crit" | sed "s/^/[$ctr] /" || true
                    done
                fi
                ;;
            whisper-server|llama-cpp|stt-proxy)
                journalctl --user -u "$SERVICE" -o short --no-pager -n 100 "$@"
                ;;
            --help|-h)
                echo "Usage: ai-stack logs [service|errors|--help]"
                echo ""
                echo "Services:"
                echo "  whisper-server  STT service logs (journald)"
                echo "  llama-cpp       LLM service logs (journald)"
                echo "  stt-proxy       STT Proxy logs (journald)"
                echo "  errors          Show errors from all services"
                echo ""
                echo "Container services (auto-detected from compose):"
                for ctr in $(podman compose -f "$COMPOSE_FILE" ps --services 2>/dev/null); do
                    echo "  $ctr"
                done
                echo ""
                echo "Options:"
                echo "  --since=1h      Time range"
                echo "  -f              Follow mode"
                ;;
            *)
                if [ -f "$COMPOSE_FILE" ] && podman compose -f "$COMPOSE_FILE" ps --services 2>/dev/null | grep -q "^$SERVICE$"; then
                    podman logs "$SERVICE" --tail=100 "$@"
                else
                    echo "Unknown service: $SERVICE"
                    echo "Run 'ai-stack logs --help' for available services"
                    exit 1
                fi
                ;;
        esac
        ;;
    gpu)
        MODE=$1
        case "$MODE" in
            stt)
                ai-stack vram stt
                systemctl --user stop llama-cpp || true
                systemctl --user start whisper-server
                ;;
            llm)
                ai-stack vram llm
                systemctl --user stop whisper-server || true
                systemctl --user start llama-cpp
                ;;
            off)
                systemctl --user stop whisper-server llama-cpp || true
                ai-stack vram clear
                ;;
            status)
                ai-stack vram status
                ;;
            *)
                echo "Usage: ai-stack gpu {stt|llm|off|status}"
                exit 1
                ;;
        esac
        ;;
    vram)
        VRAM_ACTION="${1:-status}"
        shift || true

        case "$VRAM_ACTION" in
            stt)
                echo "Checking VRAM for STT..."
                loaded_model=$(curl -sf "$LLAMA_CPP_URL/models" 2>/dev/null | \
                    jq -r '.data[]? | select(.status == "loaded") | .id' 2>/dev/null | head -1)

                if [[ -n "$loaded_model" ]]; then
                    echo "LLM loaded ($loaded_model), unloading..."
                    curl -sf -X POST "$LLAMA_CPP_URL/models/unload" \
                        -H "Content-Type: application/json" \
                        -d '{}' >/dev/null 2>&1 || true
                    sleep 1
                    echo "✓ LLM unloaded"
                else
                    echo "✓ No LLM loaded"
                fi

                echo "{\"active\": \"stt\", \"timestamp\": $(date +%s)}" > \
                    "$VRAM_STATE_FILE" 2>/dev/null || true
                echo "✓ VRAM ready for STT"
                ;;
            llm)
                echo "Checking VRAM for LLM..."

                if [[ -f "$VRAM_STATE_FILE" ]]; then
                    state=$(cat "$VRAM_STATE_FILE" 2>/dev/null)
                    active=$(echo "$state" | jq -r '.active' 2>/dev/null)
                    timestamp=$(echo "$state" | jq -r '.timestamp' 2>/dev/null)
                    elapsed=$(( $(date +%s) - timestamp ))

                    if [[ "$active" == "stt" && $elapsed -lt 30 ]]; then
                        echo "STT recently active (${elapsed}s ago), waiting..."
                        sleep 2
                    fi
                fi

                echo "{\"active\": \"llm\", \"timestamp\": $(date +%s)}" > \
                    "$VRAM_STATE_FILE" 2>/dev/null || true
                echo "✓ VRAM ready for LLM"
                ;;
            status)
                echo ""
                echo "=== AI Stack VRAM Status ==="
                echo ""

                if [[ -f "$VRAM_STATE_FILE" ]]; then
                    state=$(cat "$VRAM_STATE_FILE" 2>/dev/null)
                    active=$(echo "$state" | jq -r '.active' 2>/dev/null)
                    timestamp=$(echo "$state" | jq -r '.timestamp' 2>/dev/null)
                    elapsed=$(( $(date +%s) - timestamp ))
                    echo "Active service: $active (${elapsed}s ago)"
                else
                    echo "Active service: none (no state file)"
                fi

                loaded_model=$(curl -sf "$LLAMA_CPP_URL/models" 2>/dev/null | \
                    jq -r '.data[]? | select(.status == "loaded") | .id' 2>/dev/null | head -1)
                if [[ -n "$loaded_model" ]]; then
                    echo "LLM loaded: $loaded_model"
                else
                    echo "LLM: unloaded"
                fi

                if curl -sf "$WHISPER_URL/health" >/dev/null 2>&1; then
                    echo "STT: healthy"
                else
                    echo "STT: not responding"
                fi

                if command -v nvidia-smi &>/dev/null; then
                    echo ""
                    nvidia-smi --query-gpu=memory.used,memory.free --format=csv
                fi
                echo ""
                ;;
            state)
                if [[ -f "$VRAM_STATE_FILE" ]]; then
                    jq . "$VRAM_STATE_FILE"
                else
                    echo "No state file found"
                fi
                ;;
            clear)
                rm -f "$VRAM_STATE_FILE" 2>/dev/null || true
                echo "✓ State cleared"
                ;;
            history)
                HISTORY="${VRAM_STATE_FILE%.state}-history.log"
                if [[ -f "$HISTORY" ]]; then
                    echo "=== VRAM Switch History ==="
                    tail -20 "$HISTORY"
                else
                    echo "No history available"
                fi
                ;;
            *)
                echo "Usage: ai-stack vram {stt|llm|status|state|clear|history}"
                exit 1
                ;;
        esac
        ;;
    install)
        echo "Installation is done via repo scripts, not the CLI."
        echo ""
        echo "To install:"
        echo "  1. Base setup:       bash ~/ai-stack/lib/install-base.sh"
        echo "  2. LLM server:       bash ~/ai-stack/bare-metal/llama-cpp/install.sh"
        echo "  3. STT server:       bash ~/ai-stack/bare-metal/stt/install.sh"
        echo "  4. STT Proxy:        bash ~/ai-stack/bare-metal/stt-proxy/install.sh"
        echo "  5. Start containers: ai-stack up"
        echo ""
        echo "Or use the one-liner:"
        echo "  curl -fsSL https://.../install.sh | bash"
        exit 0
        ;;
    models)
        load_env
        case "$1" in
            list)
                echo "=== Downloaded Models (HF Cache) ==="
                if command -v hf &>/dev/null; then
                    hf cache ls
                else
                    echo "HF CLI not installed. Run: ai-stack install base"
                    exit 1
                fi
                ;;
            status)
                echo "=== Model Download Status ==="
                echo ""
                echo "STT Model: deepdml/faster-whisper-large-v3-turbo-ct2"
                if [ -d "${HF_HOME:-$HOME/.cache/huggingface}/hub/models--deepdml--faster-whisper-large-v3-turbo-ct2" ]; then
                    echo "  Status: Downloaded"
                else
                    echo "  Status: Not downloaded"
                fi
                echo ""
                echo "LLM Model: unsloth/Qwen3.5-4B-GGUF:Q4_K_M"
                if [ -d "${HF_HOME:-$HOME/.cache/huggingface}/hub/models--unsloth--Qwen3.5-4B-GGUF" ]; then
                    echo "  Status: Downloaded"
                else
                    echo "  Status: Not downloaded"
                fi
                ;;
            download)
                if [ -z "$2" ]; then
                    echo "Usage: ai-stack models download <hf-repo>"
                    exit 1
                fi
                if ! command -v hf &>/dev/null; then
                    pip install -U "huggingface_hub[cli]" --quiet
                fi
                [ -n "$HF_TOKEN" ] && hf auth login --token "$HF_TOKEN" || true
                hf download "$2"
                ;;
            add-llama)
                if [ -z "$2" ] || [ -z "$3" ]; then
                    echo "Usage: ai-stack models add-llama <name> <hf-repo> [--ctx-size 4096]"
                    exit 1
                fi
                PRESETS_FILE="$AI_STACK_CONFIG_DIR/llama-cpp/presets.ini"
                if [ ! -f "$PRESETS_FILE" ]; then
                    echo "Error: presets.ini not found. Run: ai-stack install llama-cpp"
                    exit 1
                fi
                NAME="$2"; HF_REPO="$3"; CTX_SIZE="${4:-4096}"
                cat >> "$PRESETS_FILE" <<EOF

[$NAME]
hf-repo = $HF_REPO
ctx-size = $CTX_SIZE
EOF
                echo "Model added. Restart llama-cpp to apply."
                ;;
            cleanup)
                if [ "$2" = "--dry-run" ]; then
                    hf cache prune --dry-run 2>/dev/null || hf cache ls
                else
                    hf cache prune
                fi
                ;;
            *)
                echo "Usage: ai-stack models {list|status|download|add-llama|cleanup}"
                exit 1
                ;;
        esac
        ;;
    *)
        cat <<EOF
AI Stack Management CLI

Usage: ai-stack <command> [options]

Commands:
  up              Start all containers
  down            Stop all containers
  restart         Restart containers
  status          Show container status
  logs            View logs (ai-stack logs [service|errors|--help])
  gpu             GPU mode (stt|llm|off|status)
  vram            VRAM state (stt|llm|status|state|clear|history)
  models          Model management (list|status|download|add-llama|cleanup)

Environment Variables:
  WHISPER_URL     Whisper STT URL (default: http://localhost:7861)
  LLAMA_CPP_URL   llama.cpp URL   (default: http://localhost:7865)

Config: $AI_STACK_CONFIG_DIR
Data:   $AI_STACK_DATA_DIR
EOF
        exit 0
        ;;
esac
