#!/usr/bin/env bash
set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND=$1
shift || true

case "$COMMAND" in
    up)
        cd "$REPO_ROOT"
        podman compose --env-file "${HOME}/.env" -f containers/compose.yaml up -d
        ;;
    down)
        cd "$REPO_ROOT"
        podman compose -f containers/compose.yaml down
        ;;
    restart)
        cd "$REPO_ROOT"
        podman compose --env-file "${HOME}/.env" -f containers/compose.yaml restart "$@"
        ;;
    status)
        cd "$REPO_ROOT"
        podman compose -f containers/compose.yaml ps
        ;;
    logs)
        cd "$REPO_ROOT"
        podman compose -f containers/compose.yaml logs -f "$@"
        ;;
    gpu)
        MODE=$1
        case "$MODE" in
            stt)
                systemctl --user stop llama-cpp || true
                systemctl --user start whisper-api
                ;;
            llm)
                systemctl --user stop whisper-api || true
                systemctl --user start llama-cpp
                ;;
            off)
                systemctl --user stop whisper-api llama-cpp || true
                ;;
            status)
                echo "=== GPU VRAM Usage ==="
                nvidia-smi --query-gpu=memory.used,memory.free --format=csv
                echo -e "\n=== Systemd Status ==="
                systemctl --user status whisper-api llama-cpp --no-pager || true
                ;;
            *)
                echo "Usage: ai-stack gpu {stt|llm|off|status}"
                exit 1
                ;;
        esac
        ;;
    install)
        cd "$REPO_ROOT"
        export REPO_ROOT
        case "$1" in
            stt)
                bash bare-metal/stt/install.sh
                ;;
            llama-cpp)
                bash bare-metal/llama-cpp/install.sh
                ;;
            containers)
                podman compose --env-file "${HOME}/.env" -f containers/compose.yaml pull
                podman compose --env-file "${HOME}/.env" -f containers/compose.yaml up -d
                ;;
            all)
                bash lib/install-base.sh
                bash bare-metal/llama-cpp/install.sh
                bash bare-metal/stt/install.sh
                podman compose --env-file "${HOME}/.env" -f containers/compose.yaml pull
                podman compose --env-file "${HOME}/.env" -f containers/compose.yaml up -d
                ;;
            *)
                echo "Usage: ai-stack install {stt|llama-cpp|containers|all}"
                exit 1
                ;;
        esac
        ;;
    *)
        echo "Usage: ai-stack {up|down|restart|status|logs|gpu|install}"
        exit 1
        ;;
esac
